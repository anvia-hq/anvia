---
interface Props {
  variant:
    | "message"
    | "chat"
    | "composer"
    | "attachments"
    | "tool"
    | "review"
    | "completion";
  size?: "default" | "tall";
}

const { size = "default", variant } = Astro.props;
---

<div class="react-ui-preview" data-preview={variant} data-size={size}>
  {
    variant === "message" && (
      <div class="preview-app preview-app-compact" aria-label="Rendered message preview">
        <div class="preview-thread">
          <article class="preview-message preview-message-user">
            <div class="preview-message-content">Can we keep the renderer simple?</div>
          </article>
          <article class="preview-message preview-message-assistant">
            <div class="preview-message-content">
              <p>
                Start with the default renderer. Add Markdown, tool cards, or attachments only when
                the product needs them.
              </p>
              <div class="preview-tool-card">
                <header>
                  <span>searchDocs</span>
                  <span>Done</span>
                </header>
                <pre>{`{ "matches": 4 }`}</pre>
              </div>
            </div>
            <div class="preview-actions">
              <button type="button" aria-label="Copy response">
                <svg class="preview-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="9" y="9" width="11" height="11" rx="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
              </button>
              <button type="button" aria-label="Regenerate response">
                <svg class="preview-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M21 12a9 9 0 1 1-2.64-6.36"></path>
                  <path d="M21 3v6h-6"></path>
                </svg>
              </button>
            </div>
          </article>
        </div>
      </div>
    )
  }

  {
    variant === "chat" && (
      <div class="preview-app" aria-label="Rendered chat surface preview">
        <header class="preview-topbar">
          <div class="preview-brand">
            <span class="preview-brand-mark" aria-hidden="true">
              A
            </span>
            <span>Fullstack Agent</span>
          </div>
          <button class="preview-icon-button" type="button" aria-label="New chat">
            <svg class="preview-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 5v14"></path>
              <path d="M5 12h14"></path>
            </svg>
          </button>
        </header>
        <section class="preview-surface">
          <div class="preview-thread">
            <article class="preview-message preview-message-user">
              <div class="preview-message-content">Where is order A-100?</div>
            </article>
            <article class="preview-message preview-message-assistant">
              <div class="preview-message-content">
                Order A-100 is packed and waiting for carrier pickup. The latest scan was added
                twelve minutes ago.
              </div>
            </article>
            <article class="preview-message preview-message-user">
              <div class="preview-message-content">What should support do next?</div>
            </article>
            <article class="preview-message preview-message-assistant">
              <div class="preview-message-content">
                Send the customer the pickup status, attach the order summary, and ask them to check
                back after the next carrier scan.
              </div>
            </article>
          </div>
          <button class="preview-scroll-button" type="button" aria-label="Scroll to latest message">
            <svg class="preview-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 5v14"></path>
              <path d="m19 12-7 7-7-7"></path>
            </svg>
          </button>
          <div class="preview-composer">
            <button class="preview-icon-button preview-composer-control" type="button" aria-label="Attach file">
              <svg class="preview-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 5v14"></path>
                <path d="M5 12h14"></path>
              </svg>
            </button>
            <textarea
              class="preview-composer-input"
              aria-label="Message Fullstack Agent"
              placeholder="Message Fullstack Agent"
              rows={1}
            />
            <button class="preview-icon-button preview-send-button" type="button" aria-label="Send message">
              <svg class="preview-icon preview-send-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M22 2 11 13"></path>
                <path d="m22 2-7 20-4-9-9-4 20-7Z"></path>
              </svg>
            </button>
          </div>
        </section>
      </div>
    )
  }

  {
    variant === "composer" && (
      <div class="preview-app preview-app-compact" aria-label="Rendered composer preview">
        <div class="preview-composer preview-composer-large">
          <button class="preview-icon-button preview-composer-control" type="button" aria-label="Attach file">
            <svg class="preview-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 5v14"></path>
              <path d="M5 12h14"></path>
            </svg>
          </button>
          <textarea
            class="preview-composer-input"
            aria-label="Message Fullstack Agent"
            placeholder="Message Fullstack Agent"
            rows={1}
          />
          <button class="preview-icon-button preview-composer-control" type="button" aria-label="Stop response">
            <svg class="preview-icon preview-stop-icon" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="7" y="7" width="10" height="10" rx="1"></rect>
            </svg>
          </button>
          <button class="preview-icon-button preview-send-button" type="button" aria-label="Send message">
            <svg class="preview-icon preview-send-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 2 11 13"></path>
              <path d="m22 2-7 20-4-9-9-4 20-7Z"></path>
            </svg>
          </button>
        </div>
      </div>
    )
  }

  {
    variant === "attachments" && (
      <div class="preview-app preview-app-compact" aria-label="Rendered attachment composer preview">
        <div class="preview-composer preview-composer-large preview-composer-with-files">
          <div class="preview-attachment-list">
            <span>photo.png</span>
            <span>brief.pdf</span>
          </div>
          <button class="preview-icon-button preview-composer-control" type="button" aria-label="Attach file">
            <svg class="preview-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 5v14"></path>
              <path d="M5 12h14"></path>
            </svg>
          </button>
          <textarea
            class="preview-composer-input"
            aria-label="Message Fullstack Agent"
            placeholder="Message Fullstack Agent"
            rows={1}
          />
          <button class="preview-icon-button preview-send-button" type="button" aria-label="Send message">
            <svg class="preview-icon preview-send-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 2 11 13"></path>
              <path d="m22 2-7 20-4-9-9-4 20-7Z"></path>
            </svg>
          </button>
        </div>
        <div class="preview-dropzone">Drop files here, or use the attach button.</div>
      </div>
    )
  }

  {
    variant === "tool" && (
      <div class="preview-app preview-app-compact" aria-label="Rendered tool call preview">
        <div class="preview-tool-card preview-tool-standalone">
          <header>
            <span>searchDocs</span>
            <span>Done</span>
          </header>
          <section>
            <span>Input</span>
            <pre>{`{ "query": "message renderer" }`}</pre>
          </section>
          <section>
            <span>Result</span>
            <pre>{`{ "matches": 4 }`}</pre>
          </section>
        </div>
      </div>
    )
  }

  {
    variant === "review" && (
      <div class="preview-app preview-app-compact" aria-label="Rendered human input preview">
        <div class="preview-review">
          <header>
            <strong>Human review</strong>
            <span>1 pending</span>
          </header>
          <div class="preview-review-card">
            <strong>issue_refund</strong>
            <textarea aria-label="Reason" placeholder="Reason for the audit log..." />
            <div>
              <button type="button">Reject</button>
              <button type="button" class="preview-primary-button">
                Approve
              </button>
            </div>
          </div>
        </div>
      </div>
    )
  }

  {
    variant === "completion" && (
      <div class="preview-app preview-app-compact" aria-label="Rendered completion preview">
        <div class="preview-completion">
          <article>Your draft will appear here.</article>
          <textarea aria-label="Prompt" placeholder="Draft a release note..." />
          <div>
            <button type="button">Stop</button>
            <button type="button" class="preview-primary-button">
              Generate
            </button>
          </div>
        </div>
      </div>
    )
  }
</div>

<style>
  .react-ui-preview {
    margin-top: 1.25rem;
    overflow: hidden;
    border: 1px solid #2f2f2f;
    border-radius: 1rem;
    background: #171717;
    color: #ececec;
  }

  .react-ui-preview button,
  .react-ui-preview textarea {
    font: inherit;
  }

  .react-ui-preview button {
    color: inherit;
    cursor: pointer;
  }

  .preview-app {
    display: grid;
    min-height: 32rem;
    grid-template-rows: 3.5rem minmax(0, 1fr);
    background: #212121;
  }

  .react-ui-preview[data-size="tall"] .preview-app:not(.preview-app-compact) {
    min-height: 62rem;
  }

  .preview-app-compact {
    min-height: auto;
    grid-template-rows: 1fr;
    padding: 1.25rem;
  }

  .preview-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid #303030;
    background: #171717;
    padding: 0 1.125rem;
  }

  .preview-brand {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    gap: 0.625rem;
    color: #d8d8d8;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0;
  }

  .preview-brand-mark {
    display: grid;
    width: 1.75rem;
    height: 1.75rem;
    place-items: center;
    border: 1px solid #3f3f3f;
    border-radius: 0.5rem;
    background: #ececec;
    color: #171717;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .preview-icon-button,
  .preview-actions button,
  .preview-scroll-button {
    display: inline-grid;
    width: 2.25rem;
    height: 2.25rem;
    place-items: center;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: #b4b4b4;
    font-size: 0.875rem;
    line-height: 1;
  }

  .preview-icon-button:hover,
  .preview-actions button:hover,
  .preview-scroll-button:hover {
    background: #2f2f2f;
    color: #f4f4f4;
  }

  .preview-icon {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .preview-stop-icon {
    fill: currentColor;
    stroke: none;
  }

  .preview-send-icon {
    width: 1.05rem;
    height: 1.05rem;
    fill: currentColor;
    stroke: currentColor;
    stroke-width: 1.75;
  }

  .preview-surface {
    position: relative;
    display: grid;
    min-height: 0;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: 1.125rem;
    padding: 1.5rem 0 1.125rem;
  }

  .preview-thread,
  .preview-composer,
  .preview-review,
  .preview-completion,
  .preview-dropzone {
    width: min(47.5rem, calc(100% - 2rem));
    margin: 0 auto;
  }

  .preview-thread {
    display: grid;
    align-content: start;
    gap: 0.75rem;
  }

  .preview-message {
    display: grid;
    gap: 0.375rem;
  }

  .preview-message-content {
    min-width: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: #ececec;
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .preview-message-content p {
    margin: 0;
  }

  .preview-message-user {
    justify-items: end;
  }

  .preview-message-user .preview-message-content {
    max-width: min(38.75rem, 88%);
    border-radius: 1.25rem;
    background: #2f2f2f;
    padding: 0.625rem 1rem;
    color: #f4f4f4;
    line-height: 1.55;
  }

  .preview-message-assistant .preview-message-content {
    max-width: 100%;
    padding: 0.25rem 0;
  }

  .preview-actions {
    display: flex;
    min-height: 1.875rem;
    gap: 0.25rem;
  }

  .preview-actions button {
    width: 1.875rem;
    height: 1.875rem;
    color: #8f8f8f;
    font-size: 0.6875rem;
    font-weight: 700;
  }

  .preview-composer {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: end;
    gap: 0.5rem;
    overflow: hidden;
    border: 1px solid #3f3f3f;
    border-radius: 1.625rem;
    background: #2f2f2f;
    box-shadow: 0 1rem 2.5rem rgb(0 0 0 / 28%);
    padding: 0.625rem;
  }

  .preview-composer-large {
    width: min(47.5rem, 100%);
  }

  .preview-composer-with-files {
    grid-template-columns: auto minmax(0, 1fr) auto;
  }

  .preview-composer-control {
    color: #c7c7c7;
  }

  .preview-composer-input {
    width: 100%;
    min-width: 0;
    min-height: 2.25rem;
    max-height: 7rem;
    overflow-y: auto;
    border: 0;
    outline: none;
    padding: 0.5625rem 0.625rem;
    resize: none;
    background: transparent;
    color: #ececec;
    font-size: 0.9375rem;
    line-height: 1.4;
  }

  .preview-composer-input::placeholder {
    color: #9f9f9f;
  }

  .react-ui-preview .preview-send-button {
    background: #ececec;
    color: #171717;
    font-weight: 700;
  }

  .react-ui-preview .preview-send-button:hover {
    background: #ffffff;
    color: #171717;
  }

  .preview-scroll-button {
    position: absolute;
    right: 1.125rem;
    bottom: 6.25rem;
    z-index: 1;
    border: 1px solid #3f3f3f;
    background: #262626;
    box-shadow: 0 0.75rem 1.75rem rgb(0 0 0 / 28%);
    font-weight: 700;
  }

  .preview-tool-card,
  .preview-review-card,
  .preview-completion article,
  .preview-completion textarea,
  .preview-review textarea,
  .preview-dropzone {
    border: 1px solid #3a3a3a;
    border-radius: 0.75rem;
    background: #262626;
  }

  .preview-tool-card {
    display: grid;
    width: min(32rem, 100%);
    gap: 0;
    margin-top: 0.625rem;
    overflow: hidden;
    color: #d8d8d8;
  }

  .preview-tool-standalone {
    margin: 0 auto;
  }

  .preview-tool-card header,
  .preview-tool-card section {
    padding: 0.625rem 0.75rem;
  }

  .preview-tool-card header,
  .preview-review header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: #d4d4d4;
    font-size: 0.8125rem;
  }

  .preview-tool-card header {
    border-bottom: 1px solid #353535;
  }

  .preview-tool-card section {
    display: grid;
    gap: 0.375rem;
  }

  .preview-tool-card section + section {
    border-top: 1px solid #353535;
  }

  .preview-tool-card section > span {
    color: #9f9f9f;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .preview-tool-card pre {
    margin: 0;
    overflow: auto;
    white-space: pre-wrap;
    word-break: break-word;
    color: #cfcfcf;
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .preview-attachment-list {
    grid-column: 1 / -1;
    display: flex;
    min-width: 0;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .preview-attachment-list span {
    min-width: 0;
    max-width: min(16rem, 100%);
    overflow: hidden;
    border: 1px solid #3f3f3f;
    border-radius: 0.625rem;
    background: #262626;
    padding: 0.375rem 0.5rem;
    color: #d4d4d4;
    font-size: 0.8125rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .preview-dropzone {
    margin-top: 0.625rem;
    border-style: dashed;
    padding: 1rem;
    color: #b4b4b4;
    font-size: 0.9375rem;
  }

  .preview-review,
  .preview-completion {
    display: grid;
    width: min(32rem, 100%);
    gap: 0.75rem;
  }

  .preview-review-card {
    display: grid;
    gap: 0.65rem;
    padding: 0.8rem;
  }

  .preview-review-card div,
  .preview-completion div {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .preview-review-card button,
  .preview-completion button {
    min-height: 2.25rem;
    border: 1px solid #3f3f3f;
    border-radius: 999px;
    background: #2f2f2f;
    padding: 0 0.75rem;
    color: #ececec;
    font-size: 0.8125rem;
  }

  .preview-primary-button {
    border-color: #ececec !important;
    background: #ececec !important;
    color: #171717 !important;
    font-weight: 700;
  }

  .preview-completion article,
  .preview-completion textarea,
  .preview-review textarea {
    padding: 0.85rem;
    color: #ececec;
    line-height: 1.6;
  }

  .preview-completion textarea,
  .preview-review textarea {
    min-height: 5rem;
    resize: vertical;
  }

  .preview-completion textarea::placeholder,
  .preview-review textarea::placeholder {
    color: #8f8f8f;
  }

  @media (max-width: 640px) {
    .preview-app {
      min-height: 30rem;
    }

    .react-ui-preview[data-size="tall"] .preview-app:not(.preview-app-compact) {
      min-height: 46rem;
    }

    .preview-app-compact {
      min-height: auto;
      padding: 0.75rem;
    }

    .preview-topbar {
      padding: 0 0.75rem;
    }

    .preview-surface {
      padding-top: 1.125rem;
    }

    .preview-thread,
    .preview-composer,
    .preview-review,
    .preview-completion,
    .preview-dropzone {
      width: min(100% - 1.25rem, 47.5rem);
    }

    .preview-composer {
      grid-template-columns: auto minmax(0, 1fr) auto;
      border-radius: 1.25rem;
    }

    .preview-composer-with-files {
      grid-template-columns: auto minmax(0, 1fr) auto;
    }

    .preview-message-user .preview-message-content {
      max-width: 94%;
    }
  }
</style>
