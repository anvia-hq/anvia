{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"],
      "collections/*": ["./.source/*"]
    },
    "skipLibCheck": true,
    "target": "ES2022",
    "types": ["vite/client"]
  },
  "include": ["src", "content", "source.config.ts", "vite.config.ts", ".source", ".tanstack"]
}
