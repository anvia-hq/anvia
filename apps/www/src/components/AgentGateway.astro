---
import Button from "./ui/Button.astro";

const capabilities = [
  {
    label: "Models",
    title: "Switch providers without rewiring",
    body: "Use the same agent contract across OpenAI, Anthropic, Gemini, Mistral, and local model adapters.",
  },
  {
    label: "Retrieval",
    title: "Bring your own memory layer",
    body: "Attach vector stores and embedding packages only when your agent needs grounded context.",
  },
  {
    label: "Operations",
    title: "Observe every run in production",
    body: "Connect tracing, sandboxed tools, and Studio workflows around the same runtime surface.",
  },
];

---

<section id="gateway" class="bg-[#131314] px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl rounded-2xl border border-white/[0.08] bg-[#0F0F0D] px-6 py-8 shadow-[0_24px_80px_rgba(0,0,0,0.22)] sm:px-8 lg:px-10 lg:py-10">
    <div class="grid items-center gap-10 lg:grid-cols-[0.86fr_1.14fr] lg:gap-14">
      <div>
        <p class="font-mono text-[#2BF563]/70 text-[0.75rem] uppercase tracking-[0.18em]">
          Agent gateway
        </p>
        <h2 class="mt-4 max-w-2xl font-semibold text-4xl text-zinc-50 tracking-[-0.02em] sm:text-5xl">
          A cleaner path from model to product.
        </h2>
        <p class="mt-5 max-w-xl text-base text-zinc-400 leading-7 sm:text-lg">
          Compose model providers, retrieval, tools, traces, and app clients without turning your agent into integration glue.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button size="lg" data-gateway-cta="browse_packages">Browse packages</Button>
          <Button variant="ghost" size="lg" href="/docs" data-gateway-cta="read_docs">Read docs</Button>
        </div>
      </div>

      <div class="relative -mx-4 sm:mx-0">
        <img
          src="/assets/illustrations/agent-gateway-card.png"
          alt="Agent gateway connecting multiple app interfaces"
          width="1265"
          height="531"
          loading="lazy"
          decoding="async"
          class="relative w-full object-contain"
        />
      </div>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {
        capabilities.map((capability) => (
          <article>
            <p class="font-mono text-[#2BF563]/65 text-[0.68rem] uppercase tracking-[0.16em]">
              {capability.label}
            </p>
            <h3 class="mt-3 font-semibold text-xl text-zinc-100 tracking-[-0.01em]">
              {capability.title}
            </h3>
            <p class="mt-3 max-w-sm text-sm text-zinc-500 leading-6">
              {capability.body}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('[data-gateway-cta]').forEach(function(el) {
    el.addEventListener('click', function() {
      window.posthog?.capture('gateway_cta_clicked', {
        cta: el.getAttribute('data-gateway-cta')
      });
    });
  });
</script>
