---
import Button from "./ui/Button.astro";

const supportedProducts = [
  { name: "OpenAI", logo: "/assets/integrations/openai.svg", invert: true },
  { name: "Anthropic", logo: "/assets/integrations/anthropic.svg", invert: true },
  { name: "Gemini", logo: "/assets/integrations/gemini.svg" },
  { name: "Mistral", logo: "/assets/integrations/mistral.svg" },
  { name: "FastEmbed", logo: "/assets/integrations/fastembed.svg" },
  { name: "Transformers.js", logo: "/assets/integrations/huggingface.svg" },
  { name: "Langfuse", logo: "/assets/integrations/langfuse.svg" },
  { name: "OpenTelemetry", logo: "/assets/integrations/opentelemetry.svg", invert: true },
  { name: "ChromaDB", logo: "/assets/integrations/chroma.svg" },
  { name: "LanceDB", logo: "/assets/integrations/lancedb.svg", wordmark: true },
  { name: "Milvus", logo: "/assets/integrations/milvus.svg" },
  { name: "Postgres/pgvector", logo: "/assets/integrations/postgres.svg" },
  { name: "Pinecone", logo: "/assets/integrations/pinecone.svg", invert: true },
  { name: "Qdrant", logo: "/assets/integrations/qdrant.svg" },
  { name: "Redis", logo: "/assets/integrations/redis.svg" },
  { name: "Weaviate", logo: "/assets/integrations/weaviate.svg" },
];

const integrationRows = [
  supportedProducts.slice(0, 8),
  supportedProducts.slice(8),
];
---

<section id="products" class="relative isolate overflow-hidden bg-[#131314]">
  <div class="hero-field pointer-events-none absolute inset-x-0 top-0 h-full" aria-hidden="true">
  </div>

  <div class="relative mx-auto flex max-w-7xl flex-col items-center px-4 pt-24 pb-20 text-center sm:px-6 sm:pt-28 lg:px-8 lg:pt-32 lg:pb-24">
    <div class="mx-auto max-w-4xl">
      <h1
        class="text-balance font-semibold text-5xl text-zinc-50 leading-[0.95] tracking-[-0.02em] sm:text-6xl lg:text-7xl"
      >
        The TypeScript stack for{" "}
        <span class="text-[#2BF563]">production agents</span>
      </h1>

      <p class="mx-auto mt-7 max-w-2xl text-balance text-lg text-zinc-400 leading-8 sm:text-xl">
        Anvia gives you one runtime for models, retrieval, tools, tracing, and UI transports.
      </p>

      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <Button data-hero-cta="explore_packages">Explore packages</Button>
        <Button variant="outline" href="/docs" data-hero-cta="read_docs">Read docs</Button>
      </div>

      <div class="mx-auto mt-16 w-full max-w-5xl">
        <p class="font-mono text-[#2BF563]/60 text-[0.72rem] uppercase tracking-[0.18em]">
          Supported integrations
        </p>
        <div class="integration-marquee mt-6" aria-label="Supported integrations">
          {
            integrationRows.map((row, rowIndex) => (
              <div class:list={["integration-marquee__row", rowIndex === 1 && "integration-marquee__row--reverse"]}>
                <div class="integration-marquee__track" aria-hidden="true">
                  {[...row, ...row].map((product) => (
                    <div class="integration-marquee__item" data-invert={product.invert ? "true" : undefined}>
                      <img
                        src={product.logo}
                        alt=""
                        loading="lazy"
                        class:list={[
                          "integration-marquee__logo",
                          product.wordmark ? "h-4 w-auto max-w-24" : "h-4 w-4 object-contain",
                        ]}
                      />
                      {!product.wordmark && <span>{product.name}</span>}
                    </div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

  </div>
</section>

<script is:inline>
  document.querySelectorAll('[data-hero-cta]').forEach(function(el) {
    el.addEventListener('click', function() {
      window.posthog?.capture('hero_cta_clicked', {
        cta: el.getAttribute('data-hero-cta')
      });
    });
  });
</script>

<style>
  .hero-field {
    background:
      radial-gradient(ellipse 52rem 40rem at 50% 90%, rgba(43, 245, 99, 0.18), transparent 1px)
        50% 100% / 100% 100% no-repeat,
      radial-gradient(ellipse 64rem 50rem at 50% 96%, transparent 54.8%, rgba(43, 245, 99, 0.16) 55%, transparent 55.18%),
      radial-gradient(ellipse 51rem 40rem at 50% 96%, transparent 54.8%, rgba(43, 245, 99, 0.13) 55%, transparent 55.18%),
      radial-gradient(ellipse 39rem 31rem at 50% 96%, transparent 54.8%, rgba(43, 245, 99, 0.1) 55%, transparent 55.18%),
      radial-gradient(ellipse 27rem 22rem at 50% 96%, transparent 54.8%, rgba(43, 245, 99, 0.08) 55%, transparent 55.18%),
      linear-gradient(to bottom, rgba(43, 245, 99, 0.035), transparent 42%);
    background-color: #131314;
  }

  .hero-field::before,
  .hero-field::after {
    position: absolute;
    right: 0;
    left: 0;
    content: "";
  }

  .hero-field::before {
    top: 0;
    height: 100%;
    background-image: repeating-linear-gradient(
      90deg,
      transparent 0,
      transparent calc(12.5% - 1px),
      rgba(43, 245, 99, 0.075) calc(12.5% - 1px),
      rgba(43, 245, 99, 0.075) 12.5%
    );
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.5) 68%, transparent 94%);
  }

  .hero-field::after {
    bottom: -1px;
    height: 40%;
    background: linear-gradient(
      to bottom,
      rgba(19, 19, 20, 0),
      rgba(19, 19, 20, 0.82) 48%,
      #131314 100%
    );
  }

  .integration-marquee {
    position: relative;
    display: grid;
    gap: 0.75rem;
    overflow: hidden;
    padding-block: 0.125rem;
    mask-image: linear-gradient(to right, transparent, #000 12%, #000 88%, transparent);
  }

  .integration-marquee__row {
    overflow: hidden;
  }

  .integration-marquee__track {
    display: flex;
    width: max-content;
    min-width: 200%;
    gap: 0.75rem;
    animation: integration-marquee 18s linear infinite;
    will-change: transform;
  }

  .integration-marquee__row--reverse .integration-marquee__track {
    animation-duration: 22s;
    animation-direction: reverse;
  }

  .integration-marquee__item {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    gap: 0.5rem;
    min-width: max-content;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.025);
    padding: 0.5rem 0.875rem;
    color: rgba(212, 212, 216, 0.56);
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0;
    filter: grayscale(1) saturate(0.12);
  }

  .integration-marquee__logo {
    opacity: 0.68;
  }

  .integration-marquee__item[data-invert="true"] .integration-marquee__logo {
    filter: brightness(0) invert(1);
  }

  @keyframes integration-marquee {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(-50%, 0, 0);
    }
  }
</style>
