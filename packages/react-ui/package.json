{
  "name": "@anvia/react-ui",
  "version": "0.4.0",
  "description": "Composable React UI primitives for Anvia chat and completion experiences.",
  "author": "anvia",
  "maintainer": "Indra Zulfi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anvia-hq/anvia",
    "directory": "packages/react-ui"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./attachment": {
      "types": "./dist/attachment/index.d.ts",
      "import": "./dist/attachment/index.js"
    },
    "./chat": {
      "types": "./dist/chat/index.d.ts",
      "import": "./dist/chat/index.js"
    },
    "./completion": {
      "types": "./dist/completion/index.d.ts",
      "import": "./dist/completion/index.js"
    },
    "./human-input": {
      "types": "./dist/human-input/index.d.ts",
      "import": "./dist/human-input/index.js"
    },
    "./image": {
      "types": "./dist/image/index.d.ts",
      "import": "./dist/image/index.js"
    },
    "./message": {
      "types": "./dist/message/index.d.ts",
      "import": "./dist/message/index.js"
    },
    "./selection-toolbar": {
      "types": "./dist/selection-toolbar/index.d.ts",
      "import": "./dist/selection-toolbar/index.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    },
    "./thread-list": {
      "types": "./dist/thread-list/index.d.ts",
      "import": "./dist/thread-list/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.ts src/attachment/index.ts src/chat/index.ts src/completion/index.ts src/human-input/index.ts src/image/index.ts src/message/index.ts src/selection-toolbar/index.ts src/shared.ts src/thread-list/index.ts --format esm --dts --sourcemap --clean --external react --external react-dom && cp src/styles.css dist/styles.css",
    "coverage": "vitest run --coverage",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@tiptap/core": "^3.27.3",
    "@tiptap/extension-document": "^3.27.3",
    "@tiptap/extension-hard-break": "^3.27.3",
    "@tiptap/extension-mention": "^3.27.3",
    "@tiptap/extension-paragraph": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-text": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/suggestion": "^3.27.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "@anvia/react": ">=0.7.8 <1.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@anvia/react": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.5",
    "happy-dom": "20.9.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
